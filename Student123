class Student123 {
    String name;
    int marks;

    Student(String name, int marks) {
        this.name = name;
        this.marks = marks;
    }
}

public class GradeUpdater {

    static void addBonusMarks(Student s) {
        s.marks += 5;
    }

    public static void main(String[] args) {
        Student s = new Student("Ranjitha", 85);

        addBonusMarks(s);

        System.out.println(s.name + " Marks: " + s.marks);
    }
}