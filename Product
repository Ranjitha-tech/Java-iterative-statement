class Product {
    String name;
    double price;

    Product(String name, double price) {
        this.name = name;
        this.price = price;
    }
}

public class ShoppingCart {

    static void applyDiscount(Product p) {
        p.price = p.price * 0.9;
    }

    public static void main(String[] args) {
        Product p = new Product("Headphones", 2000);

        applyDiscount(p);

        System.out.println("Discounted Price: " + p.price);
    }
}