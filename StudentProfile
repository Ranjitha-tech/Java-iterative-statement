class StudentProfile {
    int id;
    String name;

    StudentProfile(int id, String name) {
        this.id = id;
        this.name = name;
    }

    void display() {
        System.out.println("ID: " + id);
        System.out.println("Name: " + name);
    }

    public static void main(String[] args) {
        StudentProfile s = new StudentProfile(101, "Ranjitha");
        s.display();
    }
}