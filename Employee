class Employee {
    void work() {
        System.out.println("Employee is working.");
    }
}

class DeveloperEmployee extends Employee {
    @Override
    void work() {
        System.out.println("Developer is writing Java code.");
    }
}

public class EmployeeWorkTracker {
    public static void main(String[] args) {
        Employee emp = new DeveloperEmployee();
        emp.work();
    }
}