class Notification {
    void send() {
        System.out.println("Sending a generic notification.");
    }
}

class EmailNotification extends Notification {
    @Override
    void send() {
        System.out.println("Sending notification through Email.");
    }
}

public class SmartNotificationDispatch {
    public static void main(String[] args) {
        Notification notify = new EmailNotification();
        notify.send();
    }
}