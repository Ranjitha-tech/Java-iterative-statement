class Laptop {
    String brand;
    int ram;

    Laptop() {
        brand = "Dell";
        ram = 8;
    }

    void upgradeRAM() {
        ram += 8;
    }

    void display() {
        System.out.println("Brand: " + brand);
        System.out.println("RAM: " + ram + " GB");
    }
}

public class LaptopDemo {
    public static void main(String[] args) {
        Laptop laptop = new Laptop();
        laptop.upgradeRAM();
        laptop.display();
    }
}